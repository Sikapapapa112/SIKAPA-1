# Environment Configuration Example
# Copy this file to firebase-config.js and replace with your actual Firebase credentials

# Firebase Configuration
# Get these from your Firebase Console: https://console.firebase.google.com

API_KEY=YOUR_API_KEY_HERE
AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
DATABASE_URL=https://YOUR_PROJECT_ID.firebaseio.com
PROJECT_ID=YOUR_PROJECT_ID
STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
APP_ID=YOUR_APP_ID

# Admin Configuration
# Set this to the email address that will have admin access
ADMIN_EMAIL=admin@sikapa.com

# Application Settings
# These can be modified for customization
COMMISSION_RATE=0.05
TIER_0_REWARD=0.5
TIER_1_REWARD=8
TIER_2_REWARD=21
TIER_3_REWARD=60
TIER_4_REWARD=100

TIER_1_BALANCE=30
TIER_2_BALANCE=100
TIER_3_BALANCE=250
TIER_4_BALANCE=500
